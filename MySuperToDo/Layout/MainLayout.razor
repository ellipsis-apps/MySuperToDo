@using MySuperToDo.Services
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@implements IDisposable

@inherits LayoutComponentBase

<RadzenLayout Style="min-height: 100vh;">
	<RadzenHeader>
		<div style="display: flex; align-items: center; width: 100%;">
			<RadzenSidebarToggle @bind-Expanded="sidebarExpanded" />
			<span style="flex: 1;"></span>
			<RadzenLink Path="https://learn.microsoft.com/aspnet/core/" Target="_blank" Text="About" Style="margin-right: 1rem;" />
			<RadzenSplitButton AlwaysOpenPopup="true"
							   ButtonStyle="ButtonStyle.Light"
							   Variant="Variant.Text"
							   Click="@OnProfileMenuItemClick">
				<ButtonContent>
					<span class="user-avatar">
						<RadzenIcon Icon="person" />
					</span>
					<span class="profile-label">Profile</span>
				</ButtonContent>
				<ChildContent>
					<RadzenSplitButtonItem Text="Logout" Value="logout" Icon="logout" Disabled="@(!_isAuthenticated)" />
				</ChildContent>
			</RadzenSplitButton>
		</div>
	</RadzenHeader>

	<RadzenSidebar @bind-Expanded="sidebarExpanded">
		<NavMenu />
	</RadzenSidebar>

	<RadzenBody>
		<div class="p-4">
			@Body
		</div>
	</RadzenBody>
</RadzenLayout>
<RadzenDialog />

@code {
	private bool sidebarExpanded = true;
	private bool _isAuthenticated;

	protected override async Task OnInitializedAsync()
	{
		AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
		var state = await AuthStateProvider.GetAuthenticationStateAsync();
		_isAuthenticated = state.User.Identity?.IsAuthenticated == true;
	}

	private void OnAuthStateChanged(Task<AuthenticationState> task)
	{
		_ = InvokeAsync(async () =>
		{
			var state = await task;
			_isAuthenticated = state.User.Identity?.IsAuthenticated == true;
			StateHasChanged();
		});
	}

	public void Dispose()
	{
		AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
	}

	private async Task OnProfileMenuItemClick(RadzenSplitButtonItem item)
	{
		if (item?.Value == "logout")
		{
			await AuthStateProvider.SignOutAsync();
			Navigation.NavigateTo("/", forceLoad: true);
		}
	}
}
