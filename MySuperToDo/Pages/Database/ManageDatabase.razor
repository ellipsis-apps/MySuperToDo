@page "/database/manage"
@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation

<PageTitle>Manage Database</PageTitle>

<div class="container mt-4">
	<RadzenCard>
		<h4>Manage Database</h4>
		<p>Choose whether to create a new local database (seed will be created and stored) or connect to an existing encrypted seed.</p>

		<div class="d-flex gap-2">
			<button class="btn btn-primary" @onclick="NewDatabase">Create New Database</button>
			<button class="btn btn-secondary" @onclick="UseExisting">Use Existing Database</button>
		</div>
	</RadzenCard>
</div>

@code {
	private void NewDatabase()
	{
		Navigation.NavigateTo("/register");
	}

	private void UseExisting()
	{
		Navigation.NavigateTo("/database/sync");
	}
}
