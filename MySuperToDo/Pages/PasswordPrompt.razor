@using MySuperToDo.Services

<div class="password-prompt-container">
	<div class="card">
		<div class="card-body">
			<h2 class="card-title mb-4">Unlock Your Database</h2>
			<p class="text-muted">Enter your password to decrypt and access your GunDB database identity.</p>

			<div class="mb-3">
				<label for="passwordInput" class="form-label">Password</label>
				<input type="password" class="form-control @(HasError ? "is-invalid" : "")" id="passwordInput"
					   @bind="Password"
					   @onkeyup="@(e => HandleKeyPress(e))"
					   placeholder="Enter your password"
					   disabled="@IsLoading" />
				@if (HasError)
				{
					<div class="invalid-feedback d-block">
						@ErrorMessage
					</div>
				}
			</div>

			<button class="btn btn-primary w-100 mb-2" @onclick="HandleUnlock" disabled="@(string.IsNullOrWhiteSpace(Password) || IsLoading)">
				@if (IsLoading)
				{
					<span class="spinner-border spinner-border-sm me-2"></span>
				}
				Unlock
			</button>

			<button class="btn btn-link w-100 text-muted" @onclick="HandleStartFresh" disabled="@IsLoading">
				Start Fresh with New Seed
			</button>
		</div>
	</div>
</div>

@code {
	[Parameter]
	public EventCallback<string> OnPasswordEntered { get; set; }

	[Parameter]
	public EventCallback OnStartFresh { get; set; }

	private string Password = string.Empty;
	private string ErrorMessage = string.Empty;
	private bool IsLoading = false;
	private bool HasError => !string.IsNullOrEmpty(ErrorMessage);

	/// <summary>
	/// Public method to set error message from parent component.
	/// </summary>
	public void SetErrorMessage(string message)
	{
		ErrorMessage = message;
		IsLoading = false;
		StateHasChanged();
	}

	/// <summary>
	/// Handles password submission when user presses Enter.
	/// </summary>
	private async Task HandleKeyPress(KeyboardEventArgs e)
	{
		if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(Password) && !IsLoading)
		{
			await HandleUnlock();
		}
	}

	/// <summary>
	/// Submits the password for decryption.
	/// </summary>
	private async Task HandleUnlock()
	{
		ErrorMessage = string.Empty;

		if (string.IsNullOrWhiteSpace(Password))
		{
			ErrorMessage = "Please enter your password.";
			return;
		}

		IsLoading = true;

		try
		{
			await OnPasswordEntered.InvokeAsync(Password);
		}
		catch (Exception ex)
		{
			ErrorMessage = $"Error: {ex.Message}";
			IsLoading = false;
		}
	}

	/// <summary>
	/// Switches to creating a new seed.
	/// </summary>
	private async Task HandleStartFresh()
	{
		await OnStartFresh.InvokeAsync();
	}
}

<style>
	.password-prompt-container {
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		padding: 2rem;
	}

	.card {
		max-width: 400px;
		width: 100%;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
	}
</style>
