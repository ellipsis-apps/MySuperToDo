@using Microsoft.JSInterop
@using MySuperToDo.Application.Interfaces
@using MySuperToDo.Domain.Entities
@inject DialogService DialogService
@inject IGunDbService GunDb

<RadzenStack Gap="1rem">
    @if (_errorMessage is not null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false">
            @_errorMessage
        </RadzenAlert>
    }

    @if (_memberships.Count == 0)
    {
        <RadzenText TextStyle="TextStyle.Body2">No other lists available.</RadzenText>
    }
    else
    {
        @foreach (var entry in _memberships)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenCheckBox TValue="bool"
                                Value="@entry.IsChecked"
                                Change="@(value => OnMembershipChangedAsync(entry, value))"
                                Disabled="@_isBusy" />
                <RadzenText TextStyle="TextStyle.Body1">@entry.ListName</RadzenText>
            </RadzenStack>
        }
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Close"
                      ButtonStyle="ButtonStyle.Light"
                      Icon="close"
                      Click="@OnClose"
                      Disabled="@_isBusy" />
    </RadzenStack>
</RadzenStack>
