@page "/lists"
@attribute [Authorize]
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MySuperToDo.Application.Interfaces
@inject IGunDbService GunDb
@inject DialogService DialogService
@inject ContextMenuService ContextMenuService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Manage To Do Lists</PageTitle>

<RadzenTree Data="@_treeData" Style="height: calc(100vh - 180px);" ItemContextMenu="@OnTreeItemContextMenu">
	<RadzenTreeLevel TextProperty="Text" ChildrenProperty="Children" Expanded="@(value => (value as TreeNode)?.Expanded ?? false)">
		<Template Context="treeItem">
			@{
				var node = treeItem.Value as TreeNode;
			}

			@if (node is not null)
			{
				var isOverdue = node.DueDate.HasValue && DateTime.UtcNow.Date > node.DueDate.Value.Date;
				var textColor = isOverdue ? "red" : (node.IsCompleted ? "darkgray" : string.Empty);

				<span @ondragover="OnDragOver"
					  @ondragover:preventDefault="true"
					  @ondrop="@(async _ => await OnDropAsync(node))"
					  @ondrop:preventDefault="true"
					  @ondblclick="@(async _ => await OnNodeDoubleClickAsync(node))"
					  style="display: flex; align-items: center; width: 100%; padding: 0.25rem 0; cursor: pointer;">
					@if (!node.SuppressDragIcon)
					{
						<span draggable="true"
							  @ondragstart="@(_ => OnDragStart(node))"
							  @ondragstart:stopPropagation="true"
							  style="display:inline-flex;cursor:grab;">
							<RadzenIcon Icon="drag_indicator" Style="margin-right: 0.4rem; color: var(--rz-text-tertiary-color, #9aa0a6);" />
						</span>
					}

					@if (node.IsTodoItem)
					{
						<RadzenCheckBox TValue="bool"
										Value="@node.IsCompleted"
										Change="@(value => OnTodoItemCheckedChangedAsync(node, value))"
										@onclick:stopPropagation="true"
										@ondblclick:stopPropagation="true"
										Style="margin-right: 0.4rem;" />
						<PriorityIcon Priority="@node.Priority" />
						<span style="@(string.IsNullOrEmpty(textColor) ? string.Empty : $"color:{textColor};")">@node.Text</span>
					}
					else
					{
						@if (!string.IsNullOrWhiteSpace(node.Id))
						{
							<RadzenCheckBox TValue="bool"
											Value="@node.IsCompleted"
											Change="@(value => OnListCheckedChangedAsync(node, value))"
											@onclick:stopPropagation="true"
											@ondblclick:stopPropagation="true"
										Style="margin-right: 0.4rem;" />
						}
						<PriorityIcon Priority="@node.Priority" />
						<span style="@(string.IsNullOrEmpty(textColor) ? string.Empty : $"color:{textColor};")">@node.Text</span>
					}
				</span>
			}
		</Template>
	</RadzenTreeLevel>
</RadzenTree>