@using MySuperToDo.Services
@inject NavigationManager Navigation

<CascadingAuthenticationState>
    @if (!IsInitialized)
    {
        @if (IsCheckingInitialization)
        {
            <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
    }
    else
    {
        <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
            <Found Context="routeData">
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                    <NotAuthorized>
                        <RedirectToLogin />
                    </NotAuthorized>
                </AuthorizeRouteView>
                <FocusOnNavigate RouteData="@routeData" Selector="h1" />
            </Found>
        </Router>
    }
</CascadingAuthenticationState>

@code {
    private bool IsInitialized;
    private bool IsCheckingInitialization = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Initialize app - authentication and GunDB setup are handled by the auth system
            IsInitialized = true;
        }
        catch (Exception ex)
        {
            // System.Diagnostics.Debug.WriteLine($"[App] Error during initialization: {ex.Message}");
            IsInitialized = true; // Still initialize app to avoid blocking
        }
        finally
        {
            IsCheckingInitialization = false;
        }
    }
}
