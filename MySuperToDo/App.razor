@using MySuperToDo.Services
@inject GunDbSeedService SeedService
@inject SeedUnlockService SeedUnlock
@inject NavigationManager Navigation

<CascadingAuthenticationState>
    @if (!IsInitialized)
    {
        @if (IsCheckingInitialization)
        {
            <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
    }
    else
    {
        <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
            <Found Context="routeData">
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                    <NotAuthorized>
                        <UnlockRedirect />
                    </NotAuthorized>
                </AuthorizeRouteView>
                <FocusOnNavigate RouteData="@routeData" Selector="h1" />
            </Found>
        </Router>
    }
</CascadingAuthenticationState>

@code {
    private bool IsInitialized;
    private bool IsCheckingInitialization = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Check if a GunDB seed exists
            var seedExists = await SeedService.SeedExistsAsync();
            System.Diagnostics.Debug.WriteLine($"[App.razor] seedExists = {seedExists}");

            if (seedExists)
            {
                // Try silent unlock from session storage. If it fails, navigate to unlock page.
                var unlocked = await SeedUnlock.TrySilentUnlockAsync();
                System.Diagnostics.Debug.WriteLine($"[App.razor] TrySilentUnlockAsync returned: {unlocked}");

                if (!unlocked)
                {
                    // Ensure the App renders the Router so the /unlock page can be shown.
                    System.Diagnostics.Debug.WriteLine("[App.razor] Navigating to /unlock");
                    IsInitialized = true;
                    Navigation.NavigateTo("/unlock", replace: true);
                    return;
                }

                await SeedUnlock.PopulateConfiguredPeersAsync();
                System.Diagnostics.Debug.WriteLine("[App.razor] Silent unlock succeeded, continuing");
            }

            IsInitialized = true;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[App] Error checking GunDB initialization: {ex.Message}");
            IsInitialized = true; // Still initialize app to avoid blocking
        }
        finally
        {
            IsCheckingInitialization = false;
        }
    }
}

